# Copy this file to .env and fill in your local values.
# .env is gitignored — never commit real credentials.

# ClickHouse address (default: 127.0.0.1:9000)
CLICKHOUSE=127.0.0.1:9000

# PostgreSQL connection string for the meta DB (accidents, project_owner, …)
DATABASE_URL=postgres://user:password@localhost:5432/ij_perf_meta

# Backend HTTP port (default: 9044)
# SERVER_PORT=9044

# NATS address — leave empty to skip (not needed for local testing)
# NATS=nats://localhost:4222

# Backend URL used by the degradation analyzer
# (defaults to https://ij-perf-api.labs.jb.gg when unset)
# BACKEND_URL=http://localhost:9044
